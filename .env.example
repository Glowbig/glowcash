# Supabase — obtén estas en https://supabase.com → tu proyecto → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXX.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Google Gemini Flash — obtén en https://aistudio.google.com/app/apikey (gratis, sin tarjeta)
EXPO_PUBLIC_GEMINI_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Gmail API — obtén en https://console.cloud.google.com (OAuth 2.0 Client ID tipo "Aplicación web")
# Úsalo para pruebas en navegador (redirect URI http://localhost:8081)
EXPO_PUBLIC_GMAIL_CLIENT_ID=XXXXXXXXXXXXXX.apps.googleusercontent.com

# Cliente OAuth tipo "Android" — se crea DESPUÉS de generar el primer APK con EAS Build
# (usa el package name com.glowbig.glowcash + huella SHA-1 del build, sin redirect URI)
EXPO_PUBLIC_GMAIL_ANDROID_CLIENT_ID=
